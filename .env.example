# Firebase (Spark plan — free, no credit card). Copy this file to `.env.local`
# and paste the values from: Firebase console → Project settings → Your apps →
# SDK setup and configuration → Config.
#
# The site runs perfectly WITHOUT these — the "Notify me" form simply stays
# hidden until they're set.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
